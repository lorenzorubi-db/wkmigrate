  {
    "description": "Spark JAR activity with dependency on upstream task",
    "input": {
      "name": "run_dependent_jar",
      "type": "DatabricksSparkJar",
      "description": "Execute JAR after data preparation",
      "depends_on": [
        {
          "activity": "prepare_data",
          "dependency_conditions": ["Succeeded"]
        }
      ],
      "policy": {
        "timeout": "0.01:30:00",
        "retry": 0,
        "retry_interval_in_seconds": 30
      },
      "main_class_name": "com.example.ProcessData"
    },
    "expected": {
      "name": "run_dependent_jar",
