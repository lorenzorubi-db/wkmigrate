[
  {
    "id": "equals_both_branches",
    "description": "IfCondition activity with equals expression and both branches",
    "input": {
      "name": "check_status",
      "type": "IfCondition",
      "description": "Check if status is success",
      "depends_on": [],
      "expression": {
        "type": "Expression",
        "value": "@equals('success', 'success')"
      },
      "if_true_activities": [
        {
          "name": "process_success",
          "type": "DatabricksNotebook",
          "description": "Handle success case",
          "depends_on": [],
          "policy": {
            "timeout": "0.01:00:00",
            "retry": 0,
            "retry_interval_in_seconds": 30
          },
          "notebook_path": "/Workspace/notebooks/success_handler"
        }
      ],
      "if_false_activities": [
        {
          "name": "process_failure",
          "type": "DatabricksNotebook",
          "description": "Handle failure case",
          "depends_on": [],
          "policy": {
            "timeout": "0.01:00:00",
            "retry": 0,
            "retry_interval_in_seconds": 30
          },
          "notebook_path": "/Workspace/notebooks/failure_handler"
        }
      ]
    },
    "expected": {
      "name": "check_status",
      "task_key": "check_status",
      "activity_type": "IfCondition",
      "description": "Check if status is success",
      "op": "EQUAL_TO",
      "left": "success",
      "right": "success",
      "child_activities_count": 2
    }
  },
