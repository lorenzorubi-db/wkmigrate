  {
    "id": "nested_foreach",
    "description": "IfCondition activity with nested ForEach in false branch",
    "input": {
      "name": "conditional_foreach",
      "type": "IfCondition",
      "description": "Conditionally run foreach",
      "depends_on": [],
      "expression": {
        "type": "Expression",
        "value": "@equals('single', 'batch')"
      },
      "if_true_activities": [
        {
          "name": "single_process",
          "type": "DatabricksNotebook",
          "notebook_path": "/Workspace/notebooks/single",
          "depends_on": [],
          "policy": {
            "timeout": "0.01:00:00"
          }
        }
      ],
      "if_false_activities": [
        {
          "name": "batch_foreach",
          "type": "ForEach",
          "depends_on": [],
          "batch_count": 5,
          "items": {
            "type": "Expression",
            "value": "@array(['a', 'b', 'c'])"
          },
          "activities": [
            {
              "name": "batch_item",
              "type": "DatabricksNotebook",
              "notebook_path": "/Workspace/notebooks/batch_item",
              "depends_on": [],
              "policy": {
                "timeout": "0.00:30:00"
              },
              "base_parameters": {
                "item": {
                  "value": "@item()",
                  "type": "Expression"
                }
              }
            }
          ]
        }
      ]
    },
    "expected": {
      "name": "conditional_foreach",
      "task_key": "conditional_foreach",
      "activity_type": "IfCondition",
      "op": "EQUAL_TO",
      "left": "single",
      "right": "batch",
      "child_activities_count": 2
    }
  },
