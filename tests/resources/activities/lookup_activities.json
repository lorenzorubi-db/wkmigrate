          "type": "AzureBlobFSReadSettings",
          "recursive": false
        },
        "format_settings": {
          "type": "DelimitedTextReadSettings"
        }
      },
      "input_dataset_definitions": [
        {
          "name": "csv_config_dataset",
          "properties": {
            "type": "DelimitedText",
            "location": {
              "type": "AzureBlobFSLocation",
              "container": "config-data",
              "folder_path": "lookups",
              "file_name": "settings.csv"
            },
            "first_row_as_header": true,
            "column_delimiter": ",",
            "quote_char": "\"",
            "escape_char": "\\",
            "encoding_name": "UTF-8"
          },
          "linked_service_definition": {
            "name": "storage-link",
            "properties": {
              "type": "AzureBlobFS",
              "url": "DefaultEndpointsProtocol=https;AccountName=configstore;EndpointSuffix=core.windows.net;",
