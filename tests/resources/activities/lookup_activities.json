[
  {
    "description": "Lookup activity - SQL source with first row only",
    "input": {
      "name": "lookup_config",
      "type": "Lookup",
      "description": "Lookup configuration from SQL table",
      "depends_on": [],
      "policy": {
        "timeout": "0.00:30:00",
        "retry": 2,
        "retry_interval_in_seconds": 60
      },
      "first_row_only": true,
      "source": {
        "type": "AzureSqlSource",
        "sql_reader_query": "SELECT TOP 1 * FROM config_table WHERE active = 1"
      },
      "input_dataset_definitions": [
        {
          "name": "sql_config_dataset",
          "properties": {
            "type": "AzureSqlTable",
            "schema_type_properties_schema": "dbo",
            "table": "config_table"
          },
          "linked_service_definition": {
            "name": "sql-server-link",
            "properties": {
              "type": "SqlServer",
              "server": "sql-prod.database.windows.net",
              "database": "config_db",
              "user_name": "etl_user",
              "authentication_type": "SQL Authentication"
            }
          }
        }
      ]
    },
    "expected": {
      "name": "lookup_config",
      "task_key": "lookup_config",
      "first_row_only": true,
      "source_query": "SELECT TOP 1 * FROM config_table WHERE active = 1",
      "source_dataset_type": "sqlserver"
    }
  },
