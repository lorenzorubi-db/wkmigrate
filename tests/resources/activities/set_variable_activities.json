  {
    "id": "variables_reference_known",
    "description": "SetVariable referencing a known pipeline variable via @variables()",
    "input": {
      "name": "set_from_variable",
      "type": "SetVariable",
      "depends_on": [],
      "variable_name": "copiedVar",
      "value": {
        "value": "@variables('sourceVar')",
        "type": "Expression"
      }
    },
    "context_variables": {
      "sourceVar": "set_source_var"
    },
    "expected": {
      "name": "set_from_variable",
      "task_key": "set_from_variable",
      "variable_name": "copiedVar",
      "variable_value": "dbutils.jobs.taskValues.get(taskKey='set_source_var', key='sourceVar')"
    }
  },
