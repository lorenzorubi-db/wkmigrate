[
  {
    "id": "static_string_value",
    "description": "SetVariable with a static string value",
    "input": {
      "name": "set_customer_name",
      "type": "SetVariable",
      "description": "Set the customer name variable",
      "depends_on": [],
      "variable_name": "customerName",
      "value": "Databricks"
    },
    "expected": {
      "name": "set_customer_name",
      "task_key": "set_customer_name",
      "description": "Set the customer name variable",
      "variable_name": "customerName",
      "variable_value": "'Databricks'"
    }
  },
  {
    "id": "activity_output_expression",
    "description": "SetVariable with an activity output expression",
    "input": {
      "name": "set_from_lookup",
      "type": "SetVariable",
      "depends_on": [],
      "variable_name": "lookupResult",
      "value": {
        "value": "@activity('GetConfig').output.firstRow",
        "type": "Expression"
      }
    },
    "expected": {
      "name": "set_from_lookup",
      "task_key": "set_from_lookup",
      "variable_name": "lookupResult",
      "variable_value": "dbutils.jobs.taskValues.get(taskKey='GetConfig', key='result')"
    }
  },
  {
    "id": "pipeline_run_id",
    "description": "SetVariable with pipeline RunId system variable",
    "input": {
      "name": "set_run_id",
      "type": "SetVariable",
      "depends_on": [],
      "variable_name": "runId",
      "value": {
        "value": "@pipeline().RunId",
        "type": "Expression"
      }
    },
    "expected": {
      "name": "set_run_id",
      "task_key": "set_run_id",
      "variable_name": "runId",
      "variable_value": "dbutils.jobs.getContext().tags().get('runId', '')"
    }
  },
  {
