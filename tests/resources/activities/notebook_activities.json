  {
    "description": "Notebook activity with dependency",
    "input": {
      "name": "run_dependent_notebook",
      "type": "DatabricksNotebook",
      "description": "Execute notebook after upstream task",
      "depends_on": [
        {
          "activity": "upstream_task",
          "dependency_conditions": ["Succeeded"]
        }
      ],
      "policy": {
        "timeout": "0.00:30:00",
        "retry": 1,
        "retry_interval_in_seconds": 30
      },
      "notebook_path": "/Workspace/notebooks/dependent_notebook"
    },
    "expected": {
      "name": "run_dependent_notebook",
      "task_key": "run_dependent_notebook",
      "activity_type": "DatabricksNotebook",
      "description": "Execute notebook after upstream task",
      "timeout_seconds": 1800,
      "max_retries": 1,
      "min_retry_interval_millis": 30000,
      "notebook_path": "/Workspace/notebooks/dependent_notebook",
      "base_parameters": null,
      "depends_on": [{"task_key": "upstream_task", "outcome": null}]
    }
  },
  {
    "description": "Notebook activity with linked service definition (cluster config)",
    "input": {
      "name": "run_notebook_with_cluster",
      "type": "DatabricksNotebook",
      "description": "Execute notebook with specific cluster",
      "depends_on": [],
      "policy": {
        "timeout": "0.04:00:00",
        "retry": 2,
        "retry_interval_in_seconds": 120
      },
      "notebook_path": "/Workspace/notebooks/heavy_notebook",
      "linked_service_definition": {
        "name": "databricks-cluster-001",
        "properties": {
          "domain": "https://adb-123456789.1.azuredatabricks.net",
          "new_cluster_node_type": "Standard_DS3_v2",
          "new_cluster_version": "13.3.x-scala2.12",
          "new_cluster_num_of_worker": "2:8",
          "new_cluster_custom_tags": {"env": "production"},
          "new_cluster_spark_conf": {"spark.sql.shuffle.partitions": "200"}
        }
      }
    },
    "expected": {
      "name": "run_notebook_with_cluster",
      "task_key": "run_notebook_with_cluster",
      "activity_type": "DatabricksNotebook",
      "description": "Execute notebook with specific cluster",
      "timeout_seconds": 14400,
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "notebook_path": "/Workspace/notebooks/heavy_notebook",
      "base_parameters": null,
      "depends_on": [],
      "new_cluster": {
        "service_name": "databricks-cluster-001",
        "service_type": "databricks",
        "host_name": "https://adb-123456789.1.azuredatabricks.net",
        "node_type_id": "Standard_DS3_v2",
        "spark_version": "13.3.x-scala2.12",
        "autoscale": {"min_workers": 2, "max_workers": 8},
        "custom_tags": {"env": "production", "CREATED_BY_WKMIGRATE": ""},
        "spark_conf": {"spark.sql.shuffle.partitions": "200"}
      }
    }
  },
