[
  {
    "description": "Copy activity - CSV to Delta Lake",
    "input": {
      "name": "copy_csv_to_delta",
      "type": "Copy",
      "description": "Copy CSV files to Delta Lake table",
      "depends_on": [],
      "policy": {
        "timeout": "0.02:00:00",
        "retry": 2,
        "retry_interval_in_seconds": 60
      },
      "source": {
        "type": "DelimitedTextSource",
        "store_settings": {
          "type": "AzureBlobFSReadSettings",
          "recursive": true
        },
        "format_settings": {
          "type": "DelimitedTextReadSettings"
        }
      },
      "sink": {
        "type": "AzureDatabricksDeltaLakeSink",
        "pre_copy_script": "TRUNCATE TABLE target_table"
      },
      "input_dataset_definitions": [
        {
          "name": "source_csv_dataset",
          "properties": {
            "type": "DelimitedText",
            "location": {
              "type": "AzureBlobFSLocation",
              "container": "raw-data",
              "folder_path": "csv",
              "file_name": "*.csv"
            },
            "first_row_as_header": true,
            "column_delimiter": ",",
            "quote_char": "\"",
            "escape_char": "\\",
            "encoding_name": "UTF-8"
          },
          "linked_service_definition": {
            "name": "abfs-storage",
            "properties": {
              "type": "AzureBlobFS",
              "url": "DefaultEndpointsProtocol=https;AccountName=sourceaccount;EndpointSuffix=core.windows.net;",
              "storage_account_name": "DefaultEndpointsProtocol=https;AccountName=sourceaccount;EndpointSuffix=core.windows.net;"
            }
          }
        }
      ],
      "output_dataset_definitions": [
        {
          "name": "sink_delta_dataset",
          "properties": {
            "type": "AzureDatabricksDeltaLakeDataset",
            "database": "analytics",
            "table": "processed_data",
            "catalog": "main"
          },
          "linked_service_definition": {
            "name": "databricks-cluster",
            "properties": {
              "type": "AzureDatabricks",
              "domain": "https://adb-123456789.1.azuredatabricks.net",
              "new_cluster_node_type": "Standard_DS3_v2",
              "new_cluster_version": "13.3.x-scala2.12",
              "new_cluster_num_of_worker": "2:4"
            }
          }
        }
      ],
      "translator": {
        "type": "TabularTranslator",
        "mappings": [
          {
            "source": {"name": "id"},
            "sink": {"name": "record_id", "type": "String"}
          },
          {
            "source": {"name": "timestamp"},
            "sink": {"name": "event_time", "type": "Timestamp"}
          },
          {
            "source": {"name": "value"},
            "sink": {"name": "amount", "type": "Decimal"}
          }
        ]
      }
    },
    "expected": {
      "name": "copy_csv_to_delta",
      "task_key": "copy_csv_to_delta",
      "activity_type": "Copy",
      "source_dataset_type": "DelimitedText",
      "sink_dataset_type": "delta",
      "column_mapping_count": 3
    }
  },
  {
    "description": "Copy activity - Parquet to Parquet",
    "input": {
      "name": "copy_parquet",
      "type": "Copy",
      "description": "Copy Parquet files between locations",
      "depends_on": [],
      "policy": {
        "timeout": "0.01:00:00",
        "retry": 1,
        "retry_interval_in_seconds": 30
      },
      "source": {
        "type": "ParquetSource",
        "store_settings": {
          "type": "AzureBlobFSReadSettings",
          "recursive": true
        }
      },
      "sink": {
        "type": "ParquetSink",
        "store_settings": {
          "type": "AzureBlobFSWriteSettings"
        }
      },
      "input_dataset_definitions": [
        {
          "name": "source_parquet",
          "properties": {
            "type": "Parquet",
            "location": {
              "type": "AzureBlobFSLocation",
              "container": "raw",
              "folder_path": "parquet",
              "file_name": "data.parquet"
            },
            "compression_codec": "snappy"
          },
          "linked_service_definition": {
            "name": "source-abfs",
            "properties": {
              "type": "AzureBlobFS",
              "url": "DefaultEndpointsProtocol=https;AccountName=source;EndpointSuffix=core.windows.net;",
              "storage_account_name": "DefaultEndpointsProtocol=https;AccountName=source;EndpointSuffix=core.windows.net;"
            }
          }
        }
      ],
      "output_dataset_definitions": [
        {
          "name": "sink_parquet",
          "properties": {
            "type": "Parquet",
            "location": {
              "type": "AzureBlobFSLocation",
              "container": "processed",
              "folder_path": "output",
              "file_name": "result.parquet"
            },
            "compression_codec": "gzip"
          },
          "linked_service_definition": {
            "name": "sink-abfs",
            "properties": {
              "type": "AzureBlobFS",
              "url": "DefaultEndpointsProtocol=https;AccountName=sink;EndpointSuffix=core.windows.net;",
              "storage_account_name": "DefaultEndpointsProtocol=https;AccountName=sink;EndpointSuffix=core.windows.net;"
            }
          }
        }
      ]
    },
    "expected": {
      "name": "copy_parquet",
      "task_key": "copy_parquet",
      "activity_type": "Copy",
      "source_dataset_type": "Parquet",
      "sink_dataset_type": "Parquet"
    }
  },
  {
