      },
      "input_dataset_definitions": [
        {
          "name": "source_json",
          "properties": {
            "type": "Json",
            "location": {
              "type": "AzureBlobFSLocation",
              "container": "events",
              "folder_path": "daily",
              "file_name": "events.json"
            },
            "encoding_name": "UTF-8",
            "compression_codec": {"type": "gzip"}
          },
          "linked_service_definition": {
            "name": "json-storage",
