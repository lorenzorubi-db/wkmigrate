              "new_cluster_node_type": "Standard_DS3_v2",
              "new_cluster_version": "13.3.x-scala2.12",
              "new_cluster_num_of_worker": "1:2"
            }
          }
        }
      ]
    },
    "expected": {
      "name": "copy_json_to_delta",
      "task_key": "copy_json_to_delta",
      "activity_type": "Copy",
      "source_dataset_type": "Json",
      "sink_dataset_type": "delta"
    }
  },
  {
    "description": "Copy activity - SQL to Delta with column mapping",
    "input": {
      "name": "copy_sql_to_delta",
      "type": "Copy",
      "description": "Copy SQL table to Delta Lake",
      "depends_on": [],
      "policy": {
        "timeout": "0.03:00:00",
        "retry": 3,
        "retry_interval_in_seconds": 120
      },
      "source": {
        "type": "AzureSqlSource",
        "sql_reader_query": "SELECT * FROM customers WHERE updated_at > @lastRun"
      },
      "sink": {
        "type": "AzureDatabricksDeltaLakeSink",
        "import_settings": {
          "type": "AzureDatabricksDeltaLakeImportCommand"
        }
      },
      "input_dataset_definitions": [
        {
          "name": "source_sql",
          "properties": {
            "type": "AzureSqlTable",
            "schema_type_properties_schema": "dbo",
            "table": "customers"
          },
          "linked_service_definition": {
            "name": "sql-server",
            "properties": {
              "type": "SqlServer",
              "server": "sql-prod.database.windows.net",
              "database": "crm_db",
              "user_name": "etl_user",
              "authentication_type": "SQL Authentication"
            }
          }
        }
      ],
      "output_dataset_definitions": [
        {
          "name": "sink_delta",
          "properties": {
            "type": "AzureDatabricksDeltaLakeDataset",
            "database": "customer_data",
            "table": "customers_delta",
            "catalog": "prod"
          },
          "linked_service_definition": {
            "name": "databricks-prod",
            "properties": {
              "type": "AzureDatabricks",
              "domain": "https://adb-999999999.1.azuredatabricks.net",
              "new_cluster_node_type": "Standard_D8s_v3",
              "new_cluster_version": "14.0.x-scala2.12",
              "new_cluster_num_of_worker": "4:16"
            }
          }
        }
      ],
      "translator": {
        "type": "TabularTranslator",
        "mappings": [
          {
            "source": {"name": "customer_id"},
            "sink": {"name": "id", "type": "Long"}
          },
          {
            "source": {"name": "full_name"},
            "sink": {"name": "name", "type": "String"}
          },
          {
            "source": {"name": "email_address"},
            "sink": {"name": "email", "type": "String"}
          },
          {
            "source": {"ordinal": 4},
            "sink": {"name": "created_date", "type": "Date"}
          }
        ]
      }
    },
    "expected": {
      "name": "copy_sql_to_delta",
      "task_key": "copy_sql_to_delta",
      "activity_type": "Copy",
      "source_dataset_type": "sqlserver",
      "sink_dataset_type": "delta",
      "column_mapping_count": 4
    }
  },
