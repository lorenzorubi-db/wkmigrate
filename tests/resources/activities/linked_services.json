[
  {
    "description": "Azure Databricks linked service with autoscaling cluster",
    "input": {
      "name": "databricks-autoscale-cluster",
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "properties": {
        "type": "AzureDatabricks",
        "description": "Databricks cluster with autoscaling",
        "domain": "https://adb-123456789.1.azuredatabricks.net",
        "new_cluster_node_type": "Standard_DS3_v2",
        "new_cluster_version": "13.3.x-scala2.12",
        "new_cluster_num_of_worker": "2:10",
        "new_cluster_custom_tags": {
          "environment": "production",
          "team": "data-engineering"
        },
        "new_cluster_driver_node_type": "Standard_DS4_v2",
        "new_cluster_spark_conf": {
          "spark.sql.shuffle.partitions": "400",
          "spark.databricks.delta.preview.enabled": "true"
        },
        "new_cluster_spark_env_vars": {
          "PYSPARK_PYTHON": "/databricks/python3/bin/python3",
          "ENV": "prod"
        },
        "new_cluster_init_scripts": [
          "/Users/admin@company.com/init_scripts/setup.sh",
          "dbfs:/FileStore/scripts/common_init.sh",
          "/Volumes/main/scripts/volume_init.sh"
        ],
        "new_cluster_log_destination": "dbfs:/cluster-logs/production"
      }
    },
    "expected": {
      "service_name": "databricks-autoscale-cluster",
      "service_type": "databricks",
      "host_name": "https://adb-123456789.1.azuredatabricks.net",
      "node_type_id": "Standard_DS3_v2",
      "spark_version": "13.3.x-scala2.12",
      "driver_node_type_id": "Standard_DS4_v2",
      "autoscale": {"min_workers": 2, "max_workers": 10},
      "custom_tags": {
        "environment": "production",
        "team": "data-engineering",
        "CREATED_BY_WKMIGRATE": ""
      },
      "spark_conf": {
        "spark.sql.shuffle.partitions": "400",
        "spark.databricks.delta.preview.enabled": "true"
      },
      "spark_env_vars": {
        "PYSPARK_PYTHON": "/databricks/python3/bin/python3",
        "ENV": "prod"
      },
      "init_scripts": [
        {"workspace": {"destination": "/Users/admin@company.com/init_scripts/setup.sh"}},
        {"dbfs": {"destination": "dbfs:/FileStore/scripts/common_init.sh"}},
        {"volumes": {"destination": "/Volumes/main/scripts/volume_init.sh"}}
      ],
      "cluster_log_conf": {"dbfs": {"destination": "dbfs:/cluster-logs/production"}}
    }
  },
